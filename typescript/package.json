{
  "name": "@huntrecht/sdk",
  "version": "0.1.0",
  "description": "Official TypeScript SDK for the Huntrecht Platform API v1",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["huntrecht", "api", "sdk", "b2b", "ecommerce", "trading"],
  "author": "Huntrecht <dev@huntrecht.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/huntrecht/sdk-typescript"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {},
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "eslint": "^8.56.0",
    "@types/node": "^20.11.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0"
  }
}
